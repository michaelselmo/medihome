# MediHome - Variables de Entorno
# Copiar este archivo a .env y ajustar los valores

# Puerto del servidor (default: 3000)
PORT=3000

# Clave secreta para firmar JWT (CAMBIAR en produccion)
SECRET=medihome_secret_key_2026

# Ruta de la base de datos SQLite
DB_PATH=./medihome.db

# --- Notificaciones por correo ---
# Configuracion SMTP (Gmail)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=michaelselmom@gmail.com

# App Password de Gmail (NO es la contraseña normal)
# Obtener en: https://myaccount.google.com/apppasswords
# Requiere: Activar verificacion en 2 pasos en la cuenta de Google
EMAIL_APP_PASSWORD=COLOCAR_AQUI_EL_APP_PASSWORD

# Correo del administrador que recibe las notificaciones
EMAIL_ADMIN=michaelselmom@gmail.com
