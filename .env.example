# MediHome - Variables de Entorno
# Copiar este archivo a .env y ajustar los valores

# Puerto del servidor (default: 3000)
PORT=3000

# Clave secreta para firmar JWT (CAMBIAR en produccion)
SECRET=medihome_secret_key_2026

# Ruta de la base de datos SQLite
DB_PATH=./medihome.db

# --- Notificaciones por correo (Resend) ---
# Obtener API Key en: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# Direccion del remitente (debe estar verificada en Resend)
# Para pruebas locales usa: Acme <onboarding@resend.dev>
# En produccion usa: MediHome <notificaciones@tudominio.com>
EMAIL_FROM=MediHome <onboarding@resend.dev>

# Correo del administrador que recibe las notificaciones
EMAIL_ADMIN=michaelselmom@gmail.com

# Token para la ruta de prueba de correo GET /api/test-email?token=valor
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TEST_EMAIL_TOKEN=COLOCAR_AQUI_EL_TOKEN